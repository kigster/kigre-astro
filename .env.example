# Disqus shortname for comments (used at build time)
PUBLIC_DISQUS_SHORTNAME=kiguino

# ── AI digest (tools/digest) ────────────────────────────────────────────────
# The generator picks a provider at runtime. Precedence:
#   1. AI_PROVIDER below   2. first API key present (anthropic → gemini → openai)
# Set AI_PROVIDER to force one: anthropic | gemini | openai
# AI_PROVIDER=anthropic

# Provide the key for whichever provider you use (only one is required):
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...            # or GOOGLE_API_KEY

# Optional overrides:
# DIGEST_MODEL=claude-sonnet-4-5   # override the provider's default model
# DIGEST_DAYS_BACK=7               # arXiv lookback window
# DIGEST_OUT_DIR=notes/drafts/ai-digests
