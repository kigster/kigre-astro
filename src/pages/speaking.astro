---
import BaseLayout from '../layouts/BaseLayout.astro';
import TalkPdfModal from '../components/TalkPdfModal.tsx';
import talks from '../data/talks.json';

// Talk data lives in src/data/talks.json (sourced from reinvent.one/#speaking —
// edit it there to add new talks; bin/fetch-talk-pdfs.sh reads the same file).
// Each talk derives from its pdf filename: a slug (also the header anchor and
// the ?talk= deep-link value), a local cover image, and the same-origin PDF
// mirror that react-pdf renders in the modal.
const items = talks.map((t) => {
  const slug = t.pdf.split('/').pop().replace(/\.pdf$/, '');
  return {
    ...t,
    slug,
    img: `/assets/images/talks/${slug}.jpg`,
    localPdf: `/assets/talks/pdfs/${slug}.pdf`,
  };
});
---
<BaseLayout title="Speaking" description="Talks and presentations on software architecture, Ruby, DevOps, concurrency, and scaling distributed systems.">
  <div class="page">
    <div class="eyebrow">// speaking</div>
    <h1>Talks & <em>Presentations</em></h1>
    <p class="lead">On software architecture, Ruby, DevOps, concurrency, and scaling distributed systems. Click any cover to open the slides right here — or share a deck with <code>?talk=…</code> in the URL.</p>
  </div>
  <div class="talks">
    {items.map((t) => (
      <div class="talk">
        <div class="yr">{t.year}</div>
        <div class="talk-body">
          <a class="talk-thumb" href={t.localPdf} target="_blank" rel="noopener" data-talk={t.slug} aria-label={`Open the slides: ${t.title}`}>
            <img src={t.img} alt="" loading="lazy" />
          </a>
          <h3 id={t.slug}><a class="talk-title" href={`#${t.slug}`}>{t.title}</a></h3>
          <p>{t.blurb}</p>
          <a class="pdf" href={t.localPdf} target="_blank" rel="noopener" data-talk={t.slug}>View slides ↗</a>
        </div>
      </div>
    ))}
  </div>

  {/* clicking a [data-talk] link above opens this react-pdf modal instead of
      the raw PDF; ?talk=<slug> deep-links straight into an open deck */}
  <TalkPdfModal
    client:only="react"
    talks={items.map(({ slug, year, title, localPdf, pdf }) => ({ slug, year, title, pdf: localPdf, remote: pdf }))}
  />

  <script>
    // GitHub-style permalink icons on each talk header — same pattern as the
    // blog post headings in [...permalink].astro, so any talk can be
    // shared/deep-linked by its #slug anchor.
    const LINK_ICON =
      '<svg viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M7.775 3.275a.75.75 0 0 0 1.06 1.06l1.25-1.25a2 2 0 1 1 2.83 2.83l-2.5 2.5a2 2 0 0 1-2.83 0 .75.75 0 0 0-1.06 1.06 3.5 3.5 0 0 0 4.95 0l2.5-2.5a3.5 3.5 0 0 0-4.95-4.95l-1.25 1.25Zm-4.69 9.64a2 2 0 0 1 0-2.83l2.5-2.5a2 2 0 0 1 2.83 0 .75.75 0 0 0 1.06-1.06 3.5 3.5 0 0 0-4.95 0l-2.5 2.5a3.5 3.5 0 0 0 4.95 4.95l1.25-1.25a.75.75 0 0 0-1.06-1.06l-1.25 1.25a2 2 0 0 1-2.83 0Z"></path></svg>';
    document
      .querySelectorAll<HTMLHeadingElement>('.talks h3[id]')
      .forEach((heading) => {
        const a = document.createElement('a');
        a.className = 'heading-anchor';
        a.href = `#${heading.id}`;
        a.innerHTML = LINK_ICON;
        a.setAttribute('aria-label', `Link to "${heading.textContent ?? ''}"`);
        heading.prepend(a);
      });
  </script>
</BaseLayout>
