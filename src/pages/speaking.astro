---
import BaseLayout from '../layouts/BaseLayout.astro';

// Sourced from reinvent.one/#speaking — edit this array to add new talks.
const talks = [
  { year: '2026', title: 'Inquirex: Deterministic DSL meets Probabilistic LLM', blurb: 'A collection of gems defining a flexible DSL for deterministic, type-safe lead-qualification forms — with AST branching, TTY and HTML interfaces, and an LLM extracting answers from free-form text. Presented at SF Ruby.', pdf: 'https://reinvent.one/images/talks/pdfs/2026.inquirex.pdf' },
  { year: '2025', title: 'Thread Safety in Ruby and Rails', blurb: 'Thread-safety concepts, synchronization techniques, and race-condition prevention in Ruby and Rails using Mutex, Queue, and concurrency patterns.', pdf: 'https://reinvent.one/images/talks/pdfs/2025.thread-safety-in-ruby-and-rails.pdf' },
  { year: '2025', title: 'Terraform Is Better as a Terragrunt Sandwich', blurb: 'Terraform fundamentals and the pain of pure-Terraform projects, then Terragrunt as the fix — with refactoring examples and guidance on when the added layer pays off.', pdf: 'https://reinvent.one/images/talks/pdfs/2025.terraform-with-terragrunt.pdf' },
  { year: '2025', title: 'Dev Tooling for You and Me', blurb: 'When shell scripting is appropriate, how to write self-documenting dev scripts, and practical tooling for Rails workflows.', pdf: 'https://reinvent.one/images/talks/pdfs/2025.bash-tooling-for-rails.pdf' },
  { year: '2024', title: 'Concurrency in Ruby 3', blurb: 'A deep dive into Ruby 3 concurrency — Threads, Fibers, Processes, EventMachine, and Ractors — and when to reach for each.', pdf: 'https://reinvent.one/images/talks/pdfs/2024.ruby-3-concurrency.pdf' },
  { year: '2024', title: 'Design for Loose Coupling', blurb: 'How tight coupling emerges, and strategies for modularizing codebases with clear, enforceable boundaries. Presented at the Ruby SF Meetup.', pdf: 'https://reinvent.one/images/talks/pdfs/2024.design-for-loose-coupling.pdf' },
  { year: '2023', title: 'Loose Coupling with Gems and Packwerk', blurb: 'Part 1 of an advancing-Ruby series on libraries, gems, and Rails — what makes software easy to change, well-tested, and properly decoupled.', pdf: 'https://reinvent.one/images/talks/pdfs/2023.loose-coupling-with-gems-and-packwerk.pdf' },
  { year: '2021', title: 'Designing Distributed Software for Scale', blurb: 'Software design in three views — Data Model, State Model, System Model — and why early team collaboration on design has lasting implications.', pdf: 'https://reinvent.one/images/talks/pdfs/2021.software-design.pdf' },
  { year: '2018', title: 'Behold, the Unix Command Line', blurb: 'An introduction to Unix, shells, and the command line — from MULTICS and Ken Thompson to practical power-user skills.', pdf: 'https://reinvent.one/images/talks/pdfs/2018.be-friends-with-unix.pdf' },
  { year: '2015', title: 'From Obvious to Ingenious — Scaling Web Apps', blurb: 'A 100+ slide deep dive on incrementally scaling web applications on PostgreSQL — caching, sharding, and beyond. SF PostgreSQL User Group.', pdf: 'https://reinvent.one/images/talks/pdfs/2015.from-obvious-to-ingenius--scaling-web-apps.pdf' },
];

// derive a slug + local cover image from each pdf filename
const items = talks.map((t) => {
  const slug = t.pdf.split('/').pop().replace(/\.pdf$/, '');
  return { ...t, slug, img: `/assets/images/talks/${slug}.jpg` };
});
---
<BaseLayout title="Speaking" description="Talks and presentations on software architecture, Ruby, DevOps, concurrency, and scaling distributed systems.">
  <div class="page">
    <div class="eyebrow">// speaking</div>
    <h1>Talks & <em>Presentations</em></h1>
    <p class="lead">On software architecture, Ruby, DevOps, concurrency, and scaling distributed systems. Click any cover to open the slides (PDF) in a new tab.</p>
  </div>
  <div>
    {items.map((t) => (
      <div class="talk">
        <div class="yr">{t.year}</div>
        <div class="talk-body">
          <a class="talk-thumb" href={t.pdf} target="_blank" rel="noopener" aria-label={`Open the slides (PDF, new tab): ${t.title}`}>
            <img src={t.img} alt="" loading="lazy" />
          </a>
          <h3>{t.title}</h3>
          <p>{t.blurb}</p>
          <a class="pdf" href={t.pdf} target="_blank" rel="noopener">View slides ↗</a>
        </div>
      </div>
    ))}
  </div>
</BaseLayout>
