---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = await getCollection('blog', ({ data }) => !data.draft);
const counts = {};
for (const p of posts) for (const t of p.data.tags) counts[t] = (counts[t] || 0) + 1;

// Tag cloud: scale each tag by how often it's used. Alphabetical order gives the
// classic cloud feel; size + brightness encode frequency.
const tags = Object.entries(counts).sort((a, b) => a[0].localeCompare(b[0]));
const nums = tags.map(([, n]) => n);
const min = Math.min(...nums);
const max = Math.max(...nums);
// map a count onto [0,1]; guard the all-equal case (max === min)
const scale = (n) => (max === min ? 0.5 : (n - min) / (max - min));
const MIN_PX = 13;
const MAX_PX = 32;
const size = (n) => (MIN_PX + scale(n) * (MAX_PX - MIN_PX)).toFixed(1);
// brighter (closer to --fg) the more a tag is used
const tone = (n) => (45 + scale(n) * 55).toFixed(0);
---
<BaseLayout title="Tags" description="Browse posts by tag.">
  <div class="page">
    <div class="eyebrow">// tags</div>
    <h1>Browse by <em>tag</em></h1>
    <p class="lead">{tags.length} tags across {posts.length} posts.</p>
    <div class="tag-cloud">
      {tags.map(([t, n]) => (
        <a
          href={`/tags/${encodeURIComponent(t)}`}
          style={`font-size:${size(n)}px; color:color-mix(in srgb, var(--fg) ${tone(n)}%, var(--muted))`}
          title={`${n} post${n === 1 ? '' : 's'}`}
        >#{t}<span class="cnt">{n}</span></a>
      ))}
    </div>
  </div>
</BaseLayout>
