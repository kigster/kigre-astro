---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const authors = await getCollection('authors');
const authorOf = (post) =>
  post.data.author ? authors.find((a) => a.id === post.data.author.id) : null;
const fmt = (d) =>
  `${d.getFullYear()}.${String(d.getMonth() + 1).padStart(2, '0')}.${String(d.getDate()).padStart(2, '0')}`;
---
<BaseLayout title="Index" description="Engineering notes on scaling, Ruby, DevOps and questionable hardware — by Konstantin Gredeskoul.">
  <header class="ghead">
    <div class="eyebrow">// the archive · since 2012</div>
    <h1>Everything I've <em>written</em>,<br />in order.</h1>
    <div class="sub">{posts.length} posts · scaling, ruby, devops & questionable hardware</div>
  </header>

  <div class="idx">
    {posts.map((post, i) => {
      const author = authorOf(post);
      return (
        <div class={post.data.type === 'digest' ? 'row is-digest' : 'row'}>
          <div class="num">{String(posts.length - i).padStart(2, '0')}</div>
          <div class="mid">
            {post.data.heroImage && (
              <div class="thumb">
                <img src={post.data.heroImage} alt="" loading="lazy" />
              </div>
            )}
            <div class="meta">
              {post.data.type === 'digest' ? (
                <span class="ai-tag">// AI in the News</span>
              ) : (
                <span class="cat">{post.data.category}</span>
              )}
              <span class="date">{fmt(post.data.date)}</span>
              {author && (
                <a class="byline-link" href={`/authors/${post.data.author.id}`}>{author.data.name}</a>
              )}
            </div>
            {/* the title is the post link; ::after stretches it over the whole row */}
            <h2><a class="row-link" href={post.data.permalink}>{post.data.title}</a></h2>
            {post.data.description && <p>{post.data.description}</p>}
          </div>
        </div>
      );
    })}
  </div>
</BaseLayout>
