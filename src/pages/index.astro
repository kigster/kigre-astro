---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const fmt = (d) =>
  `${d.getFullYear()}.${String(d.getMonth() + 1).padStart(2, '0')}.${String(d.getDate()).padStart(2, '0')}`;
---
<BaseLayout title="Index" description="Engineering notes on scaling, Ruby, DevOps and questionable hardware — by Konstantin Gredeskoul.">
  <header class="ghead">
    <div class="eyebrow">// the archive · since 2012</div>
    <h1>Everything I've <em>written</em>,<br />in order.</h1>
    <div class="sub">{posts.length} posts · scaling, ruby, devops & questionable hardware</div>
  </header>

  <div class="idx">
    {posts.map((post, i) => (
      <a class="row" href={post.data.permalink}>
        <div class="num">{String(posts.length - i).padStart(2, '0')}</div>
        <div class="mid">
          {post.data.heroImage && (
            <div class="thumb">
              <img src={post.data.heroImage} alt="" loading="lazy" />
            </div>
          )}
          <div class="meta">
            <span class="cat">{post.data.category}</span>
            <span class="date">{fmt(post.data.date)}</span>
          </div>
          <h2>{post.data.title}</h2>
          {post.data.description && <p>{post.data.description}</p>}
        </div>
      </a>
    ))}
  </div>
</BaseLayout>
