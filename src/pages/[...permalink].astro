---
import { getCollection, getEntry, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Comments from '../components/Comments.astro';
import MermaidRenderer from '../components/MermaidRenderer.astro';

export async function getStaticPaths() {
  const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
  );

  return posts.map((post, i) => {
    // permalink is "/YYYY/MM/DD/slug.html". Strip leading slash AND trailing .html;
    // build:{format:'file'} re-appends .html, yielding the exact legacy path.
    const param = post.data.permalink.replace(/^\//, '').replace(/\.html$/, '');
    const recent = posts.filter((p) => p.id !== post.id).slice(0, 5);
    return { params: { permalink: param }, props: { post, recent } };
  });
}

const { post, recent } = Astro.props;
const { Content, headings } = await render(post);
// Table of contents for the left popup sidebar: the body's h2–h4 (the title is
// rendered separately, not part of Content). Indent is relative to the
// shallowest heading present, so a post that starts at h3 isn't over-indented.
const toc = headings.filter((h) => h.depth >= 2 && h.depth <= 4);
const tocMinDepth = toc.length ? Math.min(...toc.map((h) => h.depth)) : 2;
const author = post.data.author ? await getEntry(post.data.author) : null;
const isDigest = post.data.type === 'digest';
const d = post.data.date;
const fmtLong = d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const fmtShort = (x) =>
  `${x.getFullYear()}.${String(x.getMonth() + 1).padStart(2, '0')}.${String(x.getDate()).padStart(2, '0')}`;
const fullUrl = `https://kig.re${post.data.permalink}`;
// MM/DD/YYYY for the <title>; UTC so the date matches the frontmatter regardless
// of the build machine's timezone (a local read shifts the 06-25 post to 06-24)
const fmtSlash = `${String(d.getUTCMonth() + 1).padStart(2, '0')}/${String(d.getUTCDate()).padStart(2, '0')}/${d.getUTCFullYear()}`;
const authorName = author ? author.data.name : 'Konstantin Gredeskoul';
const pageTitle = `${post.data.title} — by ${authorName}, ${fmtSlash}`;
---
<BaseLayout title={pageTitle} exactTitle description={post.data.description} canonical={fullUrl}>
  <div class="post">
    <article class={isDigest ? 'article is-digest' : 'article'} data-pagefind-body>
      {isDigest ? (
        <div class="ai-stamp">// AI in the News</div>
      ) : (
        <div class="cat">// {post.data.category}</div>
      )}
      <h1>{post.data.title}</h1>
      <div class="byline">
        <span>{fmtLong}</span>
        <span class="dot"></span>
        {author ? (
          <a class="byline-author" href={`/authors/${post.data.author.id}`}>{author.data.name}</a>
        ) : (
          <span>Konstantin Gredeskoul</span>
        )}
      </div>
      {post.data.heroImage && (
        <img class="hero-img" src={post.data.heroImage} alt={post.data.title} />
      )}
      <div class="prose">
        {isDigest && (
          <div class="markdown-alert markdown-alert-important">
            <p class="markdown-alert-title">AI-Generated Content Follows</p>
            <hr />
            <br />
            <p>This article was generated by Claude based on the last couple of weeks of
            published research in an area related to the following blog post, or in some cases the previous blog post.</p>
            <br />
            <p>This post's theme is: <strong class="yellow">{post.data.common_theme}</strong>.</p>
            {post.data.theme_article_link && post.data.theme_article_title && (
              <p>Related post: <a href={post.data.theme_article_link}>{post.data.theme_article_title}</a>.</p>
            )}
          </div>
        )}
        <Content />
      </div>
      {post.data.tags.length > 0 && (
        <div class="tags">
          {post.data.tags.map((t) => (
            <a href={`/tags/${encodeURIComponent(t)}`}>#{t}</a>
          ))}
        </div>
      )}
    </article>

    <aside class="panel">
      <div class="pt">
        <span>// recent posts</span>
        <button class="panel-collapse" id="panelCollapse" aria-label="Hide sidebar" title="Hide sidebar">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M9 6l6 6-6 6" />
          </svg>
        </button>
      </div>
      {recent.map((p, i) => (
        <a class="ritem" href={p.data.permalink}>
          <div class="rn">{String(i + 1).padStart(2, '0')}</div>
          <h3>{p.data.title}</h3>
          <div class="rd">{fmtShort(p.data.date)}</div>
        </a>
      ))}
      <a class="allbtn" href="/">View full index →</a>
    </aside>

    <!-- collapsed-state grab tab: only this click restores the sidebar -->
    <button class="panel-reopen" id="panelReopen" aria-label="Show sidebar" title="Show recent posts">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M15 6l-6 6 6 6" />
      </svg>
      <span>Recent</span>
    </button>

    {toc.length > 0 && (
      <>
        <!-- left-edge grab tab: opens the table-of-contents popup -->
        <button class="toc-tab" id="tocTab" aria-label="Table of contents" aria-expanded="false" aria-controls="tocPanel" title="Table of contents">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01" />
          </svg>
          <span>Contents</span>
        </button>

        <!-- left popup sidebar: the post's table of contents -->
        <aside class="toc-panel" id="tocPanel" aria-label="Table of contents" aria-hidden="true">
          <div class="toc-head">
            <span>// on this page</span>
            <button class="toc-close" id="tocClose" aria-label="Close table of contents" title="Close">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M15 6l-6 6 6 6" />
              </svg>
            </button>
          </div>
          <nav class="toc-nav">
            {toc.map((h) => (
              <a
                class="toc-link"
                href={`#${h.slug}`}
                data-toc-slug={h.slug}
                style={`--toc-indent:${h.depth - tocMinDepth}`}
              >{h.text}</a>
            ))}
          </nav>
        </aside>
      </>
    )}

    {post.data.comments && (
      <Comments identifier={post.data.permalink} title={post.data.title} url={fullUrl} />
    )}
  </div>

  <MermaidRenderer />

  <script>
    // Collapsible recent-posts sidebar. The "sb-collapsed" class on <html> is the
    // single source of truth. The state is intentionally NOT persisted — it lives
    // only for the current page view, so every new blog page starts expanded.
    const root = document.documentElement;
    const collapseBtn = document.getElementById('panelCollapse');
    const reopenBtn = document.getElementById('panelReopen');
    function setCollapsed(collapsed: boolean) {
      root.classList.toggle('sb-collapsed', collapsed);
      collapseBtn?.setAttribute('aria-expanded', String(!collapsed));
    }
    collapseBtn?.setAttribute('aria-expanded', String(!root.classList.contains('sb-collapsed')));
    collapseBtn?.addEventListener('click', () => setCollapsed(true));
    reopenBtn?.addEventListener('click', () => setCollapsed(false));
  </script>

  <script>
    // Left table-of-contents popup. "toc-open" on <html> is the single source of
    // truth (not persisted). Opens from the left edge; closes on the X, on a
    // click outside, on Escape, or after jumping to a section.
    const docEl = document.documentElement;
    const tocTab = document.getElementById('tocTab');
    const tocPanel = document.getElementById('tocPanel');
    const tocClose = document.getElementById('tocClose');
    if (tocTab && tocPanel) {
      const setTocOpen = (open: boolean) => {
        docEl.classList.toggle('toc-open', open);
        tocTab.setAttribute('aria-expanded', String(open));
        tocPanel.setAttribute('aria-hidden', String(!open));
      };
      tocTab.addEventListener('click', () => setTocOpen(!docEl.classList.contains('toc-open')));
      tocClose?.addEventListener('click', () => setTocOpen(false));
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape') setTocOpen(false); });
      // click-outside: close when the click lands off both the panel and the tab
      document.addEventListener('click', (e) => {
        if (!docEl.classList.contains('toc-open')) return;
        const t = e.target as Node;
        if (tocPanel.contains(t) || tocTab.contains(t)) return;
        setTocOpen(false);
      });
      const links = Array.from(tocPanel.querySelectorAll<HTMLAnchorElement>('.toc-link'));
      links.forEach((a) => a.addEventListener('click', () => setTocOpen(false)));

      // scroll-spy: highlight the TOC entry for the section currently in view
      const bySlug = new Map(links.map((a) => [a.dataset.tocSlug, a]));
      const heads = links
        .map((a) => document.getElementById(a.dataset.tocSlug || ''))
        .filter((el): el is HTMLElement => !!el);
      if (heads.length && 'IntersectionObserver' in window) {
        let active: HTMLAnchorElement | null = null;
        const setActive = (slug: string | undefined) => {
          if (!slug) return;
          const a = bySlug.get(slug);
          if (!a || a === active) return;
          active?.classList.remove('is-active');
          a.classList.add('is-active');
          active = a;
        };
        const io = new IntersectionObserver(
          (entries) => {
            const visible = entries
              .filter((en) => en.isIntersecting)
              .sort((x, y) => x.boundingClientRect.top - y.boundingClientRect.top)[0];
            if (visible) setActive(visible.target.id);
          },
          // bias the "active" band toward the top of the viewport, under the header
          { rootMargin: '-110px 0px -65% 0px', threshold: 0 }
        );
        heads.forEach((h) => io.observe(h));
      }
    }
  </script>
</BaseLayout>
