---
import BaseLayout from '../layouts/BaseLayout.astro';

// Top projects sourced from reinvent.one/#open-source (github.com/kigster).
// Sorted by stars. Edit to feature different repos.
const repos = [
  { name: 'cmake-project-template', lang: 'C++', stars: 945, desc: 'Jump-start a C/C++ project that builds libraries, binaries, and a working unit-test suite. Uses CMake and is deliberately minimal.' },
  { name: 'puma-daemon', lang: 'Ruby', stars: 39, desc: 'Restores automatic daemonization to Puma v5/v6 after it was removed from the gem itself.' },
  { name: 'simple-feed', lang: 'Ruby', stars: 335, desc: 'Flexible time-ordered activity feeds for social apps. Events are pushed and fanned out to users, then returned as a pre-populated ordered list.' },
  { name: 'gomoku-mono-repo', lang: 'C, Rust, ReactJS', stars: 2, desc: 'This mono repo contains the C99 terminal version of the game Gomoku as well as the HTTP network daemon capable of playing the game vi JSON with the ReactJS frontend. The FastAPI server with a PostgreSQL connection sits between for authentication, persistence, and routing. Finally, there is a Rust version of the gomoku-httpd daemon which parallelizes across available vCPU. This is still work in progressm.'},
  { name: 'bashmatic', lang: 'Shell', stars: 172, desc: '900+ BASH DSL functions for UNIX command-line power users. Über toolkit optimized for humans. See bashmatic.dev.' },
  { name: 'sym', lang: 'Ruby', stars: 138, desc: 'CLI and Ruby API that makes encrypting and decrypting sensitive data trivial — usability-first symmetric encryption with keychain support.' },
  { name: 'inquirex/inquirex', lang: 'Ruby', stars: 255, desc: 'Flexible, deterministic DSL for typed lead-qualification forms — with AST branching, TTY and HTML interfaces, and an LLM extracting answers from free-form text.' },
  { name: 'laser-cutter', lang: 'Ruby', stars: 98, desc: 'Generates PDFs for cutting notched boxes on a laser cutter. An extensible, well-tested framework for laser-cut box templates.' },
  { name: 'ventable', lang: 'Ruby', stars: 62, desc: 'Event/Observable support for plain Ruby, with grouping of observers and wrapping notifications in blocks like transaction handling.' },
  { name: 'warp-dir', lang: 'Ruby', stars: 41, desc: 'A drop-in superset of the nifty `wd` ZSH module — written in Ruby, works with any shell.' },
  { name: 'arli', lang: 'Ruby / C++', stars: 30, desc: 'Arduino library manager decoupled from any IDE, plus a project generator based on arduino-cmake.' },
];
const totalStars = repos.reduce((s, r) => s + r.stars, 0);
---
<BaseLayout title="Open Source" description="Open-source projects by Konstantin Gredeskoul — 200+ repos across Ruby, C++, Arduino, Shell and more.">
  <div class="page">
    <div class="eyebrow">// open source</div>
    <h1>Open <em>Source</em></h1>
    <p class="lead">
      200+ public repositories and 200M+ RubyGems downloads. A selection of favorites below —
      the full list lives on <a href="https://github.com/kigster" style="color:var(--o2)">github.com/kigster</a>.
    </p>
    <p>
      <blockquote style="padding-left: 20px;">
        <p>
          You can actually see some of the repos in action:
        </p>
        <ul style="padding-left: 50px;">
          <li><a class="link" target="_blank" href="https://reinvent.one">ReinventONE</a> — my consulting and training company</li>
          <li><a class="link" target="_blank" href="https://qualified.at">Inquirex</a> — my AI-powered lead qualification tool</li>
          <li><a class="link" target="_blank" href="https://bashmatic.dev">Bashmatic.Dev</a> — BASH DSL for UNIX command-line power users</li>
          <li><a class="link" target="_blank" href="https://app.gomoku.games/">Play Gomoku for Free</a> — Using this ReactJS frontend with a C99 terminal version of the game Gomoku as well as the HTTP network daemon capable of playing the game vi JSON</li>
        </ul>
      <p>
        the full list lives on <a href="https://github.com/kigster" style="color:var(--o2)">github.com/kigster</a>.
      </p>
    </blockquote>  
    </p>
  </div>
  <div class="oss-grid">
    {repos.map((r) => {
      // a name with a "/" is already "owner/repo"; otherwise default to kigster
      const slug = r.name.includes('/') ? r.name : `kigster/${r.name}`;
      return (
        <div class="oss">
          <div class="top">
            <h3><a href={`https://github.com/${slug}`} target="_blank" rel="noopener">{r.name}</a></h3>
            <span class="stars">★ {r.stars}</span>
          </div>
          <div class="lang">{r.lang}</div>
          <p>{r.desc}</p>
        </div>
      );
    })}
  </div>
</BaseLayout>
