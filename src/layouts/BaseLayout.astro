---
import '../styles/global.css';
import Search from 'astro-pagefind/components/Search.astro';
// `exactTitle` opts out of the global " — kig.re" suffix for pages that pass a
// fully-composed <title> they want rendered verbatim (index + blog posts).
const { title, description, canonical, exactTitle = false } = Astro.props;
const pathname = Astro.url.pathname;
// Canonical URL: posts pass their exact legacy permalink; every other page
// falls back to its own absolute URL so search engines see one canonical per page.
// build.format:'file' makes pathname end in `.html` (and `/index.html` for dir
// indexes) — normalize to the clean URLs our internal links actually use.
const cleanPath = pathname.replace(/index\.html$/, '').replace(/\.html$/, '') || '/';
const canonicalURL = canonical ?? new URL(cleanPath, Astro.site).href;
const isActive = (p) => (p === '/' ? pathname === '/' : pathname.startsWith(p));
const navItems = [
{ href: '/', label: 'Index' },
{ href: '/speaking', label: 'Speaking' },
{ href: '/open-source', label: 'Open Source' },
{ href: '/about', label: 'About' },
{ href: '/tags', label: 'Tags' },
];
// Color-scheme swatches (replaces the old dropdown). `id` doubles as the URL
// hash a shared link carries (#azure, #light-earth, …); bg/accent are a small
// two-tone preview of each palette.
const themeSwatches = [
{ id: 'dark-glass', name: 'Dark Glass', bg: '#140c02', accent: '#ff8c00' },
{ id: 'azure', name: 'Azure', bg: '#2d3c59', accent: '#e5ba41' },
{ id: 'light-forest', name: 'Light Forest', bg: '#39c6a0', accent: '#ff0052' },
{ id: 'light-earth', name: 'Light Earth', bg: '#f7f1de', accent: '#9d6638' },
{ id: 'light', name: 'Light', bg: '#fffcf5', accent: '#ff8c00' },
];
---
<!doctype html>
<html lang="en" data-theme="dark-glass">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title ? (exactTitle ? title : `${title} — kig.re`) : 'kig.re'}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/x-icon" href="/assets/images/favicon/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/assets/images/favicon/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/assets/images/favicon/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/assets/images/favicon/apple-touch-icon.png" />
    <link rel="manifest" href="/assets/images/favicon/site.webmanifest" />
    <link rel="alternate" type="application/rss+xml" title="kig.re" href="/rss.xml" />
    <script is:inline>
      // set theme before paint to avoid flash. Priority: a theme carried in the
      // URL hash (#azure — so shared links keep their scheme) > the saved choice
      // > dark-glass (default).
      (function () {
      const themes = ['dark-glass', 'azure', 'light-forest', 'light-earth', 'light'];
      const hash = location.hash.replace(/^#/, '');
      const saved = localStorage.getItem('theme');
      const theme = themes.includes(hash) ? hash : (themes.includes(saved) ? saved : 'dark-glass');
      document.documentElement.setAttribute('data-theme', theme);
    })();
      // the collapsed-sidebar state is intentionally NOT persisted — every page
      // load starts with the sidebar visible.
    </script>
  </head>
  <body>
    <header class="site-header" id="siteHeader">
      <div class="wrap">
        <nav class="nav">
          <div class="nav-left">
            <a href={pathname.startsWith('/about') ? '/' : '/about'} class="logo" aria-label={pathname.startsWith('/about') ? 'Back to index' : 'About kig.re'}>
              <img src="/assets/images/logos/kigre-v2-logo-07-round.png" alt="kig.re" class="logo-img" />
            </a>
            <a href="/" class="home-btn" aria-label="Home" title="Home">
              <svg width="16" height="16" viewBox="0 0 576 512" fill="currentColor" aria-hidden="true">
                <path d="M575.8 255.5c0 18-15 32.1-32 32.1l-32 0 .7 160.2c0 2.7-.2 5.4-.5 8.1l0 16.2c0 22.1-17.9 40-40 40l-16 0c-1.1 0-2.2 0-3.3-.1c-1.4 .1-2.8 .1-4.2 .1L416 512l-24 0c-22.1 0-40-17.9-40-40l0-24 0-64c0-17.7-14.3-32-32-32l-64 0c-17.7 0-32 14.3-32 32l0 64 0 24c0 22.1-17.9 40-40 40l-24 0-31.9 0c-1.5 0-3-.1-4.5-.2c-1.2 .1-2.4 .2-3.6 .2l-16 0c-22.1 0-40-17.9-40-40l0-112c0-.9 0-1.9 .1-2.8l0-69.7-32 0c-18 0-32-14-32-32.1c0-9 3-17 10-24L266.4 8c7-7 15-8 22-8s15 2 21 7L564.8 231.5c8 7 12 15 11 24z"/>
              </svg>
            </a>
          </div>
          <div class="search-wrap">
            <Search
              className="pf-search"
              searchboxOptions={{ placeholder: 'Search' }}
              />
            <div class="theme-swatches" id="themeSwatches" role="group" aria-label="Color theme">
              {themeSwatches.map((t) => (
              <button
                type="button"
                class="swatch"
                data-theme-id={t.id}
                data-name={t.name}
                aria-label={`Color theme: ${t.name}`}
                aria-pressed="false"
                style={`--sw-bg:${t.bg};--sw-ac:${t.accent}`}
              ></button>
              ))}
            </div>
          </div>
          <div class="nav-right">
            <div class="links" id="navLinks">
              {navItems.map((it) => (
              <a href={it.href} class={isActive(it.href) ? 'active' : ''}>{it.label}</a>
              ))}
            </div>
            <button class="scroll-top" id="scrollTop" aria-label="Scroll to top" title="Scroll to top">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M12 19V5M5 12l7-7 7 7" />
              </svg>
            </button>
            <button class="nav-toggle" id="navToggle" aria-label="Menu" aria-expanded="false" aria-controls="navLinks">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true">
                <path d="M3 6h18M3 12h18M3 18h18" />
              </svg>
            </button>
          </div>
        </nav>
      </div>
    </header>

    <main class="wrap">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="wrap">
        <div class="ft-row">
          <span class="mono">© {new Date().getFullYear()} Konstantin Gredeskoul — kig.re</span>
          <span>
            <a href="https://github.com/kigster">GitHub</a> ·
            <a href="https://twitter.com/kig">Twitter</a> ·
            <a href="https://linkedin.com/in/kigster">LinkedIn</a> ·
            <a href="/rss.xml">RSS</a>
          </span>
        </div>
      </div>
    </footer>

    <script>
      // mobile nav: hamburger toggles the links dropdown (an overlay, so the
      // page content underneath never shifts). Closes on outside click / nav.
      const navToggle = document.getElementById('navToggle');
      const navLinks = document.getElementById('navLinks');
      if (navToggle && navLinks) {
        const setOpen = (open) => {
          navLinks.classList.toggle('open', open);
          navToggle.setAttribute('aria-expanded', open ? 'true' : 'false');
        };
        navToggle.addEventListener('click', (e) => {
          e.stopPropagation();
          setOpen(!navLinks.classList.contains('open'));
        });
        document.addEventListener('click', (e) => {
          if (!navLinks.contains(e.target) && !navToggle.contains(e.target)) setOpen(false);
        });
        navLinks.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setOpen(false)));
        document.addEventListener('keydown', (e) => { if (e.key === 'Escape') setOpen(false); });
      }
    </script>

    <script>
      // theme swatches: click sets + persists the theme and writes it to the URL
      // hash so the link is shareable; the active swatch shows a ring. A theme in
      // the incoming hash (shared link) is adopted and persisted on load.
      const swatchBox = document.getElementById('themeSwatches');
      if (swatchBox) {
        const root = document.documentElement;
        const swatches = Array.from(swatchBox.querySelectorAll('.swatch'));
        const ids = swatches.map((s) => s.dataset.themeId);
        const sync = () => {
          const active = root.getAttribute('data-theme');
          swatches.forEach((s) =>
            s.setAttribute('aria-pressed', String(s.dataset.themeId === active))
          );
        };
        const apply = (id, push) => {
          if (!ids.includes(id)) return;
          root.setAttribute('data-theme', id);
          localStorage.setItem('theme', id);
          if (push) history.replaceState(null, '', '#' + id);
          sync();
        };
        // a theme carried in the URL on load wins and gets persisted
        apply(location.hash.replace(/^#/, ''), false);
        sync();
        swatches.forEach((s) =>
          s.addEventListener('click', () => apply(s.dataset.themeId, true))
        );
        // back/forward or a hand-edited hash should still switch the theme
        window.addEventListener('hashchange', () =>
          apply(location.hash.replace(/^#/, ''), false)
        );
      }
    </script>

    <script>
      // fixed header: drop a hairline once scrolled, reveal the scroll-to-top arrow
      const header = document.getElementById('siteHeader');
      const toTop = document.getElementById('scrollTop');
      const onScroll = () => {
        const y = window.scrollY;
        header?.classList.toggle('scrolled', y > 4);
        toTop?.classList.toggle('visible', y > 240);
      };
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
      toTop?.addEventListener('click', () => {
        const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        window.scrollTo({ top: 0, behavior: reduce ? 'auto' : 'smooth' });
      });
    </script>

    <!-- medium-zoom: modern click-to-zoom replacing the old lightbox -->
    <script>
      import mediumZoom from 'medium-zoom';
      mediumZoom('.prose img', { background: 'rgba(20,12,2,0.92)', margin: 24 });
    </script>
    <script id="dsq-count-scr" src="//kiguino.disqus.com/count.js" async></script>

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-C18VWPMEKR"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-C18VWPMEKR');
    </script>
  </body>
</html>
